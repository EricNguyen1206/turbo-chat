# Application Configuration
NODE_ENV=production

# JWT Configuration
# Required in production, will throw an error if missing
JWT_SECRET=your-secure-production-jwt-secret

# Database Configuration (MongoDB)
# Must be a connection string accessible from Cloud Run (e.g., MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/notify_chat?retryWrites=true&w=majority

# Redis Configuration
# Must be a Redis instance accessible from Cloud Run (e.g., Upstash, Redis Labs, or Memorystore)
REDIS_URL=rediss://default:password@host:port

# CORS Configuration
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=https://your-frontend-domain.com
WS_CORS_ORIGIN=https://your-frontend-domain.com
